.vscode/
*.code-workspace
.idea/
*.iml
*.iws
*.ipr
out/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.netrwhist
Session.vim
.vim/
\#*\#
.\#*
.emacs.desktop
.emacs.desktop.lock
.spyderproject.db
.spyproject
.ropeproject
.project
.classpath
.settings/


# -----------------------------------------------------------------------------
