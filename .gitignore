.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# Testing & coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.virtualenv/
pyvenv.cfg
__pypackages__/

# Type checkers & linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Build tools
.pybuilder/
target/
Pipfile.lock
poetry.lock
.pdm.toml
.pdm-python
.pdm-build/


# -----------------------------------------------------------------------------
